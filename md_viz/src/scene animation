use crate::shapes::SphereTemplate;
pub use crate::shapes::{create_simbox, SimBox};
pub use crate::objects::{create_window, create_camera, create_control, create_light, create_axes, CameraSettings};
use three_d::core::RenderTarget; 
use three_d::Texture2D;

use md_core::particle::Particle;
use md_sim::Simulation;


/*-----------------------------------------------------------------------------------
Create structs
-------------------------------------------------------------------------------------*/
///SceneSetup:
pub struct SceneSetup {
    pub camera: CameraSettings,
    pub window_size: (u32, u32),
    pub sim_box: SimBox,
}

/// The main structure encapsulating the 3D scene elements.
pub struct Scene<'a> {
    pub context: Context,
    pub camera: Camera,
    pub control: OrbitControl,
    pub simbox: Option<Gm<BoundingBox, PhysicalMaterial>>,
    pub light: DirectionalLight,
    pub sphere_template: Option<SphereTemplate>,
    pub sphere_mesh: Option<Gm<InstancedMesh, PhysicalMaterial>>,
    pub img_target: Option<RenderTarget<'a>>,//canvas for image generation
    pub img_pixels: Option<Texture2D>,//memory buffer where img is stored.

}

impl Scene <'_> {
    /// Creates a new `Scene` instance. context: &Context, initial_viewport: Viewport,
    /// 
    /// If you are running headless pass window = None
    pub fn new(window: Option<&Window>,  scene_settings: SceneSetup)->Self{
        //If using the render loop then Some(window) is passed
        // 
        // If writing image to file pass None and a "window" is created for rendering the image to file
        let window = match window{
            Some(window) => window,
            None => &create_window(scene_settings.window_size),                    
        };
        let context = window.gl();
        let initial_viewport = window.viewport();
        let camera = create_camera(initial_viewport, &scene_settings);
        let control = create_control(&camera);
        let simbox = create_simbox(&context, &scene_settings.sim_box);
        let light = create_light(&context);

        let sphere_template = Some(SphereTemplate::new(&context));

        Self {
            context: context.clone(),
            camera,
            control,
            simbox,
            light,
            sphere_template,
            sphere_mesh: None,
            img_target: None,
            img_pixels: None,
        }
    }

    

    ///For saving simulation images to png
    pub fn save_img(&self, simulation: &Simulation, i: usize){
        self.render_objects();

    }



    /// For rendering the simulation to a live animation window.
    pub fn render(&mut self,frame_input: &mut FrameInput, particles: &[Particle]) -> FrameOutput {
        // Handle viewport and control events from frame_input
        self.camera.set_viewport(frame_input.viewport);
        self.control.handle_events(&mut self.camera, &mut frame_input.events);

        // Call the new private method to handle the actual rendering
        self.render_objects(frame_input.screen(), particles);

        FrameOutput::default()
    }

    // This renders all the objects to the window for both rendering and saving images.
    fn render_objects(
        &mut self,
        target: &mut RenderTarget,
        particles: &[Particle],
    ) {
        // This is the core logic from your original render method.
        // It's independent of FrameInput.

        // Update sphere mesh
        if let Some(template) = &self.sphere_template {
            if !particles.is_empty() {
                let transformations: Vec<Mat4> = particles
                    .iter()
                    .map(|p| {
                        Mat4::from_translation(vec3(p.position.x as f32, p.position.y as f32, p.position.z as f32))
                            * Mat4::from_scale(p.radius as f32)
                    })
                    .collect();
                let colors: Vec<Srgba> = particles.iter().map(|p| p.color).collect();
                let instances = Instances {
                    transformations,
                    texture_transformations: None,
                    colors: Some(colors),
                };
                self.sphere_mesh = Some(Gm::new(
                    InstancedMesh::new(&self.context, &instances, &template.cpu_mesh),
                    template.material.clone(),
                ));
            } else {
                self.sphere_mesh = None;
            }
        }

        // Collect all objects to be rendered
        let mut main_scene_objects: Vec<&dyn Object> = Vec::new();
        if let Some(sim_box_ref) = &self.simbox {
            main_scene_objects.push(sim_box_ref);
        }
        if let Some(sphere_mesh_ref) = &self.sphere_mesh {
            main_scene_objects.push(sphere_mesh_ref);
        }
        
        // Clear and render to the specified target
        target.clear(ClearState::color_and_depth(0.8, 0.8, 0.8, 1.0, 1.0));
        target.render(
            &self.camera,
            main_scene_objects,
            &[&self.light],
        );
    }
}
