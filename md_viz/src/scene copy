///SceneSetup:
pub struct SceneSetup {
    pub camera: CameraSettings,
    pub window_size: (u32, u32),
    pub sim_box: SimBox,
}

/// The main structure encapsulating the 3D scene elements.
pub struct Scene{
    pub camera: Camera,
    pub simbox: Option<Gm<BoundingBox, PhysicalMaterial>>,
    pub light: DirectionalLight,
    pub sphere_template: Option<SphereTemplate>,
    pub sphere_mesh: Option<Gm<InstancedMesh, PhysicalMaterial>>,
    pub context: HeadlessContext,
    pub texture: Texture2D,
    pub depth_texture: DepthTexture2D,
    pub img_target: RenderTarget<'a>,//canvas for image generation
    pub scene_settings: SceneSetup,

}

impl Scene<'_> {
    /// Creates a new `Scene` instance. context: &Context, initial_viewport: Viewport,
    /// 
    /// If you are running headless pass window = None
    pub fn new(scene_settings: SceneSetup)->Self{
        //If using the render loop then Some(window) is passed                   
        let context = HeadlessContext::new().unwrap();
        let viewport = Viewport::new_at_origo(scene_settings.window_size.0, scene_settings.window_size.1);

        let camera = create_camera(viewport, &scene_settings);
        let simbox = create_simbox(&context, &scene_settings.sim_box);
        let light = create_light(&context);

        let sphere_template = Some(SphereTemplate::new(&context));

         // Create a color texture to render into
        let mut texture = Texture2D::new_empty::<[u8; 4]>(
            &context,
            viewport.width,
            viewport.height,
            Interpolation::Nearest,
            Interpolation::Nearest,
            None,
            Wrapping::ClampToEdge,
            Wrapping::ClampToEdge,
        );

        // Also create a depth texture to support depth testing
        let mut depth_texture = DepthTexture2D::new::<f32>(
            &context,
            viewport.width,
            viewport.height,
            Wrapping::ClampToEdge,
            Wrapping::ClampToEdge,
        );

        let img_target = RenderTarget::new(
            texture.as_color_target(None),
            depth_texture.as_depth_target(),
        );

        Self {
            camera,
            simbox,
            light,
            sphere_template,
            sphere_mesh: None,
            context: context.clone(),
            texture,
            depth_texture,
            img_target,
            scene_settings,
        }
    }

    ///For saving simulation images to png
    pub fn save_img(&self, simulation: &Simulation, filename: &str)->Result<(), Box<dyn std::error::Error>>{
        self.render_objects(simulation.get_particles());
        
        let pixels: Vec<u8> = self.img_target.read_color();
        let width = self.scene_settings.window_size.0;
        let height = self.scene_settings.window_size.1;

        // Create an ImageBuffer from the raw pixel data
        let image_buffer: RgbaImage = ImageBuffer::from_raw(width, height, pixels)
        .ok_or("Failed to create ImageBuffer from raw data")?;

        // Save the image buffer to a file
        image_buffer.save(filename)?;

        Ok(())
    }

    // This renders all the objects to the window for both rendering and saving images.
fn render_objects( &mut self, particles: &[Particle]) {
        // Update sphere mesh
        if let Some(template) = &self.sphere_template {
            if !particles.is_empty() {
                let transformations: Vec<Mat4> = particles
                    .iter()
                    .map(|p| {
                        Mat4::from_translation(vec3(p.position.x as f32, p.position.y as f32, p.position.z as f32))
                            * Mat4::from_scale(p.radius as f32)
                    })
                    .collect();
                let colors: Vec<Srgba> = particles.iter().map(|p| p.color).collect();
                let instances = Instances {
                    transformations,
                    texture_transformations: None,
                    colors: Some(colors),
                };
                self.sphere_mesh = Some(Gm::new(
                    InstancedMesh::new(&self.context, &instances, &template.cpu_mesh),
                    template.material.clone(),
                ));
            } else {
                self.sphere_mesh = None;
            }
        }

        // Collect all objects to be rendered
        let mut main_scene_objects: Vec<&dyn Object> = Vec::new();
        if let Some(sim_box_ref) = &self.simbox {
            main_scene_objects.push(sim_box_ref);
        }
        if let Some(sphere_mesh_ref) = &self.sphere_mesh {
            main_scene_objects.push(sphere_mesh_ref);
        }
        
        // Clear and render to the specified target
        self.img_target.clear(ClearState::color_and_depth(0.8, 0.8, 0.8, 1.0, 1.0));
        self.img_target.render(
            &self.camera,
            main_scene_objects,
            &[&self.light],
        );
    }
}
